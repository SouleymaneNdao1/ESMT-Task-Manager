# ============================================================
#   ESMT Task Manager - .gitignore
# ============================================================

# ==============================================================
# Python / Django
# ==============================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.pyc
env/
venv/
.venv/
*.egg-info/
.eggs/
dist/
build/
*.so
.DS_Store

# Fichiers sensibles Django
backend/.env
backend/db.sqlite3
backend/media/
backend/staticfiles/

# ==============================================================
# Node.js / Angular
# ==============================================================
node_modules/
frontend/dist/
frontend/.angular/
.npm/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==============================================================
# IDE
# ==============================================================
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ==============================================================
# Tests
# ==============================================================
.coverage
htmlcov/
.pytest_cache/
*.log
