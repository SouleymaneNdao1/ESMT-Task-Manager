# Variables d'environnement ESMT Task Manager
# Copier ce fichier en .env et remplir les valeurs

# ==============================================================
# Sécurité Django
# ==============================================================
# Clé secrète (générer avec: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())")
SECRET_KEY=your-very-secret-key-here-change-in-production

# Mode debug (True pour dev, False pour prod)
DEBUG=True

# Hôtes autorisés (séparés par virgule)
ALLOWED_HOSTS=localhost,127.0.0.1

# ==============================================================
# Base de données (commenté = SQLite par défaut)
# ==============================================================
# Pour utiliser PostgreSQL, décommenter et configurer:
# DB_NAME=esmt_taskmanager
# DB_USER=postgres
# DB_PASSWORD=votre_mot_de_passe_db
# DB_HOST=localhost
# DB_PORT=5432

# ==============================================================
# Email (pour les notifications)
# ==============================================================
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=votre@gmail.com
# EMAIL_HOST_PASSWORD=votre_mot_de_passe_app
